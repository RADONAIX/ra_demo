{
  "servers": [
    {
      "id": "srv1",
      "name": "Server 1",
      "environment": "prod",
      "tags": [
        "postgres",
        "airflow",
        "superset"
      ],
      "ssh": {
        "host": "10.200.37.142",
        "port": 22,
        "username": "platum_user",
        "privateKeyEnv": "SRV1_SSH_KEY",
        "passwordEnv": "SRV1_SSH_PASSWORD"
      },
      "services": [
        {
          "id": "postgres-5432",
          "name": "PostgreSQL",
          "kind": "systemd",
          "unit": "postgresql",
          "allowedActions": [
            "status",
            "restart",
            "reload"
          ],
          "logUnit": "postgresql",
          "check": {
            "type": "tcp",
            "port": 5432
          }
        },
        {
          "id": "postgres-5433",
          "name": "PostgreSQL",
          "kind": "systemd",
          "unit": "postgresql-5433",
          "allowedActions": [
            "status",
            "restart",
            "reload"
          ],
          "logUnit": "postgresql-5433",
          "check": {
            "type": "tcp",
            "port": 5433
          }
        },
        {
          "id": "pgbouncer",
          "name": "PgBouncer",
          "kind": "systemd",
          "unit": "pgbouncer",
          "allowedActions": [
            "status",
            "start",
            "stop",
            "restart",
            "reload"
          ],
          "logUnit": "pgbouncer",
          "check": {
            "type": "tcp",
            "port": 6432
          }
        },
        {
          "id": "airflow",
          "name": "Airflow Webserver",
          "kind": "systemd",
          "unit": "airflow-webserver",
          "allowedActions": [
            "status",
            "start",
            "stop",
            "restart"
          ],
          "logUnit": "airflow-webserver",
          "web": {
            "port": 8086,
            "path": "/"
          },
          "check": {
            "type": "http",
            "port": 8086,
            "path": "/health"
          }
        },
        {
          "id": "airflow-scheduler",
          "name": "Airflow Scheduler",
          "kind": "systemd",
          "unit": "airflow-scheduler",
          "allowedActions": [
            "status",
            "start",
            "stop",
            "restart"
          ],
          "logUnit": "airflow-scheduler",
          "check": {
            "type": "http_json",
            "port": 8086,
            "path": "/health",
            "jsonPath": "scheduler.status",
            "healthyValue": "healthy"
          }
        },
        {
          "id": "superset",
          "name": "Superset",
          "kind": "systemd",
          "unit": "superset",
          "allowedActions": [
            "status",
            "restart"
          ],
          "logUnit": "superset",
          "check": {
            "type": "http",
            "port": 8088,
            "path": "/health"
          }
        },
        {
          "id": "snapshot-service",
          "name": "Dashboard Snapshot",
          "kind": "systemd",
          "unit": "snapshot.service",
          "allowedActions": [
            "status",
            "start",
            "stop",
            "restart"
          ],
          "logUnit": "snapshot.service",
          "logPath": "/opt/Dashboard_Snapshots/snapshot.log"
        },
        {
          "id": "radonaix-target",
          "name": "RADONaix Application",
          "kind": "systemd",
          "unit": "radonaix.target",
          "allowedActions": [
            "status",
            "start",
            "stop",
            "restart"
          ],
          "logUnit": "radonaix.target"
        },
        {
          "id": "summary-count-service",
          "name": "Summary Count",
          "kind": "python_script",
          "unit": "summary_count.service",
          "allowedActions": [
            "status",
            "start",
            "stop",
            "restart"
          ],
          "logUnit": "summary_count.service",
          "logPath": "/opt/Summary_count_automation/summary_count.log",
          "config": {
            "path": "/opt/Summary_count_automation/config.ini",
            "format": "env",
            "schema": {
              "type": "object",
              "properties": {
                "TARGET_DIR": { "type": "string", "title": "Target Directory" },
                "INTERVAL": { "type": "integer", "title": "Interval (seconds)" }
              }
            }
          }
        },
        {
          "id": "file-movement-service",
          "name": "File Movement",
          "kind": "python_script",
          "unit": "file-movement.service",
          "allowedActions": [
            "status",
            "start",
            "stop",
            "restart"
          ],
          "logUnit": "file-movement.service",
          "logPath": "/opt/File_Movement/file_movement.log",
          "config": {
            "path": "/opt/File_Movement/config.ini",
            "format": "env",
            "schema": {
              "type": "object",
              "properties": {
                "SOURCE_DIR": { "type": "string", "title": "Source Directory" },
                "DEST_DIR": { "type": "string", "title": "Destination Directory" },
                "INTERVAL": { "type": "integer", "title": "Interval (seconds)" }
              }
            }
          }
        }
      ]
    },
