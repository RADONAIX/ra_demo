# --- Auth ---
# 32+ char random string used to sign session JWTs.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET=replace-with-a-long-random-secret

# Bootstrap admin created on first run (change the password after logging in).
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!

# --- Data ---
# SQLite file for users + audit log.
DATABASE_PATH=./data/serverops.db

# --- Superset embedded dashboard (guest token) ---
# The dashboard talks to Superset server-side to mint a short-lived guest token; the
# browser then embeds one dashboard via Superset's Embedded SDK. Credentials stay server-side.
# In Superset: enable the EMBEDDED_SUPERSET feature flag, open the dashboard you want,
# "..." menu -> "Embed dashboard" -> enable, copy the UUID, and (optionally) allow this app's domain.
SUPERSET_URL=http://10.200.37.142:8088
SUPERSET_USERNAME=
SUPERSET_PASSWORD=
SUPERSET_PROVIDER=db
SUPERSET_DASHBOARD_UUID=

# --- Demo mode ---
# When true, SSH is NOT used; service statuses/actions are simulated so you can
# explore the UI without real servers. Set to false in production.
MOCK_MODE=true

# --- Per-server SSH secrets (referenced by config/servers.json) ---
# Provide EITHER a private key or a password per server. Never commit real values.
SRV1_SSH_KEY=
SRV1_SSH_PASSWORD=
SRV2_SSH_KEY=
SRV2_SSH_PASSWORD=
SRV3_SSH_KEY=
SRV3_SSH_PASSWORD=
